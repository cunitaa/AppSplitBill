<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_default"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarResult"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_primary"
        app:title="Rincian Tagihan"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarResult"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_default"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvResultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Makan Malam"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/blue_dark" />

                    <TextView
                        android:id="@+id/tvResultTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 250.000"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="16dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:layout_marginTop="8dp">

                        <TextView android:text="Subtotal" android:layout_columnWeight="1" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvResSubtotal" android:text="Rp 0" android:gravity="end" android:textStyle="bold" android:textColor="@color/text_primary"/>

                        <TextView android:text="Pajak &amp; Service" android:layout_columnWeight="1" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvResTax" android:text="Rp 0" android:gravity="end" android:layout_marginTop="4dp" android:textColor="@color/error_red" android:textStyle="bold"/>

                        <TextView android:text="Diskon" android:layout_columnWeight="1" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvResDiscount" android:text="Rp 0" android:gravity="end" android:layout_marginTop="4dp" android:textColor="@color/success_green" android:textStyle="bold"/>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Menu Details Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rincian Menu"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="@color/blue_primary"
                android:textSize="14sp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_default"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/layoutMenuDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <!-- Menu items will be added here -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Participants Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pembagian Orang"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="@color/blue_primary"
                android:textSize="14sp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_default">

                <LinearLayout
                    android:id="@+id/layoutParticipantsResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <!-- Dynamic rows will be added here -->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFF9C4"
                app:strokeWidth="1dp"
                app:strokeColor="#FBC02D">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tujuan Transfer:"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvPaymentDest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BCA 123456789 (A/N Budi)"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface_default"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveOnly"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selesai"
            android:layout_marginEnd="8dp"
            app:cornerRadius="12dp"
            android:padding="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareWA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bagikan WA"
            android:backgroundTint="@color/success_green"
            app:cornerRadius="12dp"
            android:padding="12dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>