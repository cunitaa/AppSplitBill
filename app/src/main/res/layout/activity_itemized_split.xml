<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_default"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarItemized"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2196F3"
        android:elevation="4dp"
        app:title="Itemized Split"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/etItemizedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Judul Tagihan (Misal: Makan Siang)"
            android:layout_marginBottom="16dp"
            android:inputType="textCapSentences" />

        <EditText
            android:id="@+id/etItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama Menu/Item"
            android:layout_marginBottom="12dp"
            android:autofillHints="none"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <EditText
                android:id="@+id/etItemPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="Harga (Rp)"
                android:inputType="number"
                android:autofillHints="none" />
            <EditText
                android:id="@+id/etItemQty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Qty"
                android:inputType="number"
                android:text="1"
                android:autofillHints="none" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TAMBAH"
                app:cornerRadius="12dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanBill"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/blue_primary"
                android:contentDescription="Scan Struk"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Pesanan:"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:id="@+id/tvItemList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belum ada item."
                android:background="@color/surface_default"
                android:textColor="@color/text_primary"
                android:padding="12dp"/>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <EditText
                android:id="@+id/etItemTax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Pajak (%)"
                android:inputType="number"
                android:autofillHints="none" />
            <EditText
                android:id="@+id/etItemService"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Servis (%)"
                android:inputType="number"
                android:autofillHints="none" />
            <EditText
                android:id="@+id/etItemDiscount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Diskon (Rp)"
                android:inputType="number"
                android:autofillHints="none" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTotalItemized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: Rp 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextItemized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LANJUT PILIH ORANG"
            android:backgroundTint="@color/blue_primary"
            app:cornerRadius="12dp"
            android:padding="12dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</LinearLayout>