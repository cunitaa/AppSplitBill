<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_default"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarItemized"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2196F3"
        android:elevation="4dp"
        app:title="Detail Tagihan"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp">

        <EditText
            android:id="@+id/etItemizedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Judul Tagihan (Misal: Makan Siang)"
            android:layout_marginBottom="12dp"
            android:inputType="textCapSentences"
            android:textColor="@color/text_primary"/>

        <!-- Add Manual Row -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_elevated">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <EditText
                    android:id="@+id/etItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama Menu/Item"
                    android:background="@null"
                    android:paddingVertical="8dp"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:autofillHints="none" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <EditText
                        android:id="@+id/etItemPrice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Harga (Rp)"
                        android:background="@null"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:autofillHints="none" />
                    <EditText
                        android:id="@+id/etItemQty"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:hint="Qty"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:inputType="number"
                        android:text="1"
                        android:autofillHints="none" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddItem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TAMBAH"
                        app:cornerRadius="12dp"
                        android:padding="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanBill"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="SCAN STRUK"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:cornerRadius="12dp"
                        android:padding="12dp"
                        android:backgroundTint="@color/blue_primary"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Menu (Bisa Edit Langsung):"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItemEditor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Extras Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface_default">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <EditText
                        android:id="@+id/etItemTax"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Pajak (%)"
                        android:inputType="number"
                        android:textSize="12sp"
                        android:autofillHints="none" />
                    <EditText
                        android:id="@+id/etItemService"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Servis (%)"
                        android:inputType="number"
                        android:textSize="12sp"
                        android:autofillHints="none" />
                    <EditText
                        android:id="@+id/etItemDiscount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Diskon (Rp)"
                        android:inputType="number"
                        android:textSize="12sp"
                        android:autofillHints="none" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTotalItemized"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total: Rp 0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextItemized"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LANJUT PILIH ORANG"
            android:backgroundTint="@color/blue_primary"
            app:cornerRadius="12dp"
            android:padding="14dp"
            android:layout_marginVertical="12dp"/>
    </LinearLayout>
</LinearLayout>